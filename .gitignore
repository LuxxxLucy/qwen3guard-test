__pycache__/
*.pyc
.venv/
.uv-cache/
uv.lock.bak

# benchmark outputs
results/*.json

# host-local run logs (Mac copies of Linux-box stdout, etc.)
linux_box_log/

# locally exported model artifacts (can be regenerated via scripts/)
